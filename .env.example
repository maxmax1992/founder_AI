# Default local development: use Codex CLI SSO from `codex login`.
AI_PROVIDER=codex-cli
CODEX_CLI_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=medium
CODEX_TEXT_VERBOSITY=medium

# Graphify is preferred when available. Set false to force the local fallback skill.
# USE_GRAPHIFY=false

# Optional: direct OpenAI API mode instead of Codex CLI SSO.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.2-codex

# Optional: use Vercel AI Gateway instead of the direct OpenAI provider.
# AI_PROVIDER=gateway
# AI_GATEWAY_API_KEY=
# CODEX_GATEWAY_MODEL=openai/gpt-5.2-codex
